{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"helpers:pinGitHubActionDigests",
		":dependencyDashboard",
		":semanticCommits",
		":gitSignOff"
	],
	"assigneesFromCodeOwners": true,
	"expandCodeOwnersGroups": true,
	"timezone": "Europe/Berlin",
	"schedule": [
		"before 5am on wednesday"
	],
	"labels": [
		"dependencies",
		"3. to review"
	],
	"baseBranchPatterns": [
		"main",
		"/^stable(.)+/"
	],
	"enabledManagers": [
		"composer",
		"github-actions",
		"npm"
	],
	"ignoreDeps": [
		"node",
		"npm",
		"php"
	],
	"packageRules": [
		{
			"description": "Bump GitHub actions monthly",
			"matchManagers": [
				"github-actions"
			],
			"extends": [
				"schedule:monthly"
			]
		},
		{
			"description": "Delay devDependency updates on main",
			"matchBaseBranches": [
				"main"
			],
			"matchDepTypes": [
				"devDependencies"
			],
			"extends": [
				"schedule:monthly"
			]
		},
		{
			"description": "Disable automerge on stable branches",
			"enabled": false,
			"matchBaseBranches": "/^stable(.)+/"
		}
	],
	"vulnerabilityAlerts": {
		"enabled": true,
		"semanticCommitType": "fix",
		"schedule": "before 7am every weekday",
		"dependencyDashboardApproval": false,
		"commitMessageSuffix": ""
	},
	"osvVulnerabilityAlerts": true
}
